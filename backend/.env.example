# ── AI / LLM ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ──────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>
DB_NAME=ai_qa_db

# ── File Storage ──────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
FAISS_DIR=faiss_indexes

# ── JWT Auth ──────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE-ME-use-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Redis (rate limiting & caching) ───────────────────────────────────────
# Local dev: redis://localhost:6379/0
# Docker:    redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
